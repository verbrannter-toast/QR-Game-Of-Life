data:text/html,<body><canvas id=%22c%22 style=%22background:%23000;width:100vw;height:100vh;image-rendering:pixelated%22></canvas><script>let sp=100,run=1,c=document.getElementById(%22c%22),x=c.getContext(%222d%22),S=40,W=S,H=S;c.width=W;c.height=H;let g=Array(W).fill(0).map(()=%3EArray(H).fill(0).map(()=%3EMath.random()%3E.7?1:0));c.onclick=e=%3E{let r=c.getBoundingClientRect(),i=(e.clientX-r.left)/r.width*W|0,j=(e.clientY-r.top)/r.height*H|0;g[i][j]^=1};document.onkeydown=e=%3E{e.key===%22ArrowUp%22?sp=Math.max(sp-50,20):e.key===%22ArrowDown%22?sp=Math.min(sp+50,1000):e.key===%22%20%22&&(run^=1,e.preventDefault())};function l(){if(run){let n=g.map(row=%3E[...row]);for(let i=0;i%3CW;i++){for(let j=0;j%3CH;j++){let a=-g[i][j];for(let d=-1;d%3C2;d++)for(let e=-1;e%3C2;e++)a+=g[(i+d+W)%25W][(j+e+H)%25H];n[i][j]=a===3||(g[i][j]===1&&a===2)?1:0}}g=n}x.clearRect(0,0,W,H);x.fillStyle=%22%230f0%22;for(let i=0;i%3CW;i++)for(let j=0;j%3CH;j++)if(g[i][j])x.fillRect(i,j,1,1);setTimeout(l,sp)}l();</script></body>